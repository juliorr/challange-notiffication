# Copy to .env and adjust if needed. .env is gitignored.

# Postgres
POSTGRES_DB=notifications
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend (Spring Boot)
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# Frontend (Vite)
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080
